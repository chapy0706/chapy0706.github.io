---
import type { Project } from '@config/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const { name, summary, image, links, structure, techStack, highlights } = project;

const linkItems = [
  { label: 'Repo', href: links.repo },
  { label: 'Production', href: links.production },
  { label: 'Docs', href: links.docs }
];
---

<article class="project-card">
  {image && (
    <figure class="project-card__figure">
      <img
        src={image}
        alt={`${name} スクリーンショット`}
        loading="lazy"
        decoding="async"
        class="project-card__img"
      />
    </figure>
  )}
  <div class="project-card__body">
    <div class="project-card__head">
      <div>
        <p class="project-card__label">Project</p>
        <h3 class="project-card__name">{name}</h3>
        <p class="project-card__summary">{summary}</p>
      </div>
      <div class="project-card__links">
        {linkItems.map((item) => (
          item.href ? (
            <a
              class="project-card__link"
              href={item.href}
              target="_blank"
              rel="noreferrer"
            >
              {item.label}
            </a>
          ) : (
            <span class="project-card__link project-card__link--tbd">
              {item.label} TBD
            </span>
          )
        ))}
      </div>
    </div>

    <div class="project-card__grid">
      <div>
        <p class="project-card__label">構成</p>
        <ul class="project-card__list">
          {structure.map((item) => (
            <li class="project-card__list-item">
              <span class="project-card__bullet"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <p class="project-card__label">技術</p>
        <ul class="project-card__list">
          {techStack.map((item) => (
            <li class="project-card__list-item">
              <span class="project-card__bullet"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <p class="project-card__label">見どころ</p>
        <ul class="project-card__list">
          {highlights.map((item) => (
            <li class="project-card__list-item">
              <span class="project-card__bullet"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</article>

<style>
  .project-card {
    border-radius: 1.5rem;
    border: 1px solid var(--line);
    background: color-mix(in oklab, var(--panel), transparent 10%);
    box-shadow: var(--shadow);
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .project-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.18);
  }

  .project-card__figure {
    overflow: hidden;
    border-bottom: 1px solid var(--line);
    background: color-mix(in oklab, var(--bg), transparent 5%);
    aspect-ratio: 9/16;
    max-height: 420px;
    margin: 0;
  }

  .project-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .project-card__body {
    padding: 2rem;
  }

  .project-card__head {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .project-card__label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--text-muted);
    margin: 0;
  }

  .project-card__name {
    margin: 0.5rem 0 0;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text);
  }

  .project-card__summary {
    margin: 0.75rem 0 0;
    font-size: 1rem;
    color: var(--text-muted);
  }

  .project-card__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .project-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border-radius: 9999px;
    border: 1px solid var(--line);
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text);
    text-decoration: none;
  }
  .project-card__link:hover {
    border-color: color-mix(in oklab, var(--text), transparent 60%);
    color: var(--text);
    text-decoration: none;
  }

  .project-card__link--tbd {
    border-style: dashed;
    color: var(--text-muted);
    cursor: default;
  }
  .project-card__link--tbd:hover {
    border-color: var(--line);
    color: var(--text-muted);
  }

  .project-card__grid {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 1024px) {
    .project-card__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .project-card__list {
    margin: 0.75rem 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .project-card__list-item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .project-card__bullet {
    margin-top: 0.375rem;
    flex-shrink: 0;
    display: inline-flex;
    height: 0.5rem;
    width: 0.5rem;
    border-radius: 9999px;
    background: color-mix(in oklab, var(--text), transparent 60%);
  }
</style>
