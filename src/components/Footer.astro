---
import { SITE, SOCIAL_LINKS } from "@config/site";

const NAV = [
  { name: "ホーム", href: "/" },
  { name: "ブログ", href: "/posts" },
  { name: "ポートフォリオ", href: "/use-cases" },
  { name: "自己紹介", href: "/about" },
  { name: "合格体験記", href: "https://mondai.ping-t.com/g/users/949178" }
] as const;

const SOCIAL = [
  {
    name: "GitHub",
    href: SOCIAL_LINKS.github,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>`,
  },
  {
    name: "Reads",
    href: SOCIAL_LINKS.reads,
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21 5c-1.11-.35-2.33-.5-3.5-.5-1.95 0-4.05.4-5.5 1.5C10.55 4.9 8.45 4.5 6.5 4.5c-1.95 0-4.05.4-5.5 1.5v14.65c0 .25.25.5.5.5.1 0 .15-.05.25-.05C3.1 20.45 5.05 20 6.5 20c1.95 0 4.05.4 5.5 1.5 1.35-.85 3.8-1.5 5.5-1.5 1.65 0 3.35.3 4.75 1.05.1.05.15.05.25.05.25 0 .5-.25.5-.5V6c-.6-.45-1.25-.75-2-1zm0 13.5c-1.1-.35-2.3-.5-3.5-.5-1.7 0-4.15.65-5.5 1.5V8c1.35-.85 3.8-1.5 5.5-1.5 1.2 0 2.4.15 3.5.5v11.5z"/></svg>`,
  },
].filter((s) => typeof s.href === "string" && s.href.length > 0);
---

<footer class="footer">
  <div class="container mx-auto px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-3">
      <!-- Summary -->
      <div class="space-y-4">
        <a href="/" class="footer__logo">
          <span class="footer__logo-icon">{"</>"}</span>
          <span class="footer__logo-name">{SITE.title}</span>
        </a>

        <p class="footer__desc">{SITE.description}</p>

        {SOCIAL.length > 0 && (
          <div class="flex flex-wrap gap-3">
            {SOCIAL.map((s) => (
              <a
                href={s.href}
                aria-label={s.name}
                class="footer__social-btn"
                target="_blank"
                rel="noreferrer"
              >
                <span class="w-5 h-5" set:html={s.icon} />
              </a>
            ))}
          </div>
        )}
      </div>

      <!-- Navigation -->
      <div class="lg:col-span-2">
        <h3 class="footer__nav-heading">リンク一覧</h3>
        <ul class="grid grid-cols-2 sm:grid-cols-4 gap-2">
          {NAV.map((item) => (
            <li>
              <a href={item.href} class="footer__nav-link">{item.name}</a>
            </li>
          ))}
        </ul>

        <div class="footer__bottom">
          <p class="footer__copy">&copy; {new Date().getFullYear()} {SITE.author}. All rights reserved.</p>
          <p class="footer__copy">Built with Astro.</p>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--line);
    background: color-mix(in oklab, var(--bg), transparent 5%);
    color: var(--text-muted);
  }

  .footer__logo {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    border-radius: 0.5rem;
    padding: 0.25rem 0.5rem;
    text-decoration: none;
    color: var(--text);
  }
  .footer__logo:hover {
    background: color-mix(in oklab, var(--text), transparent 90%);
    text-decoration: none;
  }

  .footer__logo-icon {
    display: inline-flex;
    height: 2.5rem;
    width: 2.5rem;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    background: linear-gradient(to bottom right, #2563eb, #0d9488);
    color: #fff;
    font-family: var(--font-mono);
    font-size: 0.875rem;
  }

  .footer__logo-name {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text);
  }

  .footer__desc {
    font-size: 0.875rem;
    line-height: 1.75;
    color: var(--text-muted);
    max-width: 28rem;
    margin: 0;
  }

  .footer__social-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    border: 1px solid var(--line);
    padding: 0.5rem;
    color: var(--text-muted);
    text-decoration: none;
  }
  .footer__social-btn:hover {
    background: color-mix(in oklab, var(--text), transparent 90%);
    color: var(--text);
    text-decoration: none;
  }

  .footer__nav-heading {
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text);
    margin: 0 0 1rem;
  }

  .footer__nav-link {
    font-size: 0.875rem;
    color: var(--text-muted);
    text-decoration: none;
  }
  .footer__nav-link:hover {
    color: var(--text);
    text-decoration: none;
  }

  .footer__bottom {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: center;
    justify-content: space-between;
  }
  @media (min-width: 640px) {
    .footer__bottom {
      flex-direction: row;
    }
  }

  .footer__copy {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin: 0;
  }
</style>
